lines <- readLines(url)
data_lines <- lines[5:length(lines)]
col4_values <- sapply(data_lines, function(line) {
if (nchar(line) >= 18) {
as.numeric(substr(line, 15, 18))
} else {
NA
}
})
col4_values <- col4_values[!is.na(col4_values)]
result <- sum(col4_values)
print(paste("Sum of the 4th column:", result))
result
